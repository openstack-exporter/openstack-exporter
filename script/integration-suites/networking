#!/bin/bash
# Run networking integration test only
set -xo pipefail

# shellcheck disable=SC1091
source "$(dirname "$0")/../stackenv"

set -eu

# VPNaaS metrics require the Neutron VPNaaS DevStack plugin:
#   enable_plugin neutron-vpnaas https://opendev.org/openstack/neutron-vpnaas
# DevStack uses strongSwan by default; set IPSEC_PACKAGE=libreswan where the
# target distro needs libreswan instead.

timeout="60m"

LOG_DIR=${LOG_DIR:-}
if [[ -z "${LOG_DIR}" ]]; then
    echo "LOG_DIR not set, will set a temp directory"
    LOG_DIR=/tmp/devstack-logs
fi
mkdir -p "${LOG_DIR}"

go test -v -timeout $timeout -tags "fixtures acceptance" ./integration -run '^TestNetworking' |& tee -a "${LOG_DIR}/acceptance_tests.log"
